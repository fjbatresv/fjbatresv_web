{
  "name": "javier-batres-site",
  "version": "1.0.0",
  "private": true,
  "description": "Personal website for Fernando Javier Batres Velásquez (Javier Batres) built with Angular.",
  "scripts": {
    "start": "ng serve --host=127.0.0.1 --port=4300",
    "build": "ng build --configuration production",
    "test": "ng test --watch=false",
    "lint": "ng lint",
    "format": "prettier --write \"src/**/*.{ts,html,scss,json}\"",
    "test:coverage": "ng test --watch=false --code-coverage",
    "prepare": "husky install"
  },
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "@angular/animations": "21.2.1",
    "@angular/common": "21.2.1",
    "@angular/compiler": "21.2.4",
    "@angular/core": "21.2.1",
    "@angular/forms": "21.2.1",
    "@angular/localize": "21.2.1",
    "@angular/platform-browser": "21.2.1",
    "@angular/platform-browser-dynamic": "21.2.1",
    "@angular/router": "21.2.1",
    "@ngx-translate/core": "^17.0.0",
    "@ngx-translate/http-loader": "^17.0.0",
    "@sentry/browser": "^10.30.0",
    "lodash": "^4.17.23",
    "rxjs": "^7.8.1",
    "tar": "^7.5.11",
    "tslib": "^2.6.2",
    "zone.js": "^0.16.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "21.2.1",
    "@angular-eslint/builder": "^21.0.0",
    "@angular-eslint/eslint-plugin": "^21.1.0",
    "@angular-eslint/eslint-plugin-template": "^21.1.0",
    "@angular-eslint/template-parser": "^21.0.0",
    "@angular/cli": "21.2.1",
    "@angular/compiler-cli": "21.2.1",
    "@sentry/cli": "^3.0.1",
    "@types/jasmine": "~5.1.4",
    "@types/node": "^24.10.1",
    "@typescript-eslint/parser": "^8.12.1",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-jsdoc": "^61.5.0",
    "eslint-plugin-prefer-arrow": "^1.2.3",
    "eslint-plugin-prettier": "^5.2.1",
    "gitmoji-cli": "^9.7.0",
    "husky": "^9.1.6",
    "jasmine-core": "~5.13.0",
    "karma": "~6.4.3",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "prettier": "^3.2.5",
    "svgo": "^4.0.1",
    "typescript": "~5.9.2"
  },
  "overrides": {
    "@modelcontextprotocol/sdk": "1.27.1"
  }
}
